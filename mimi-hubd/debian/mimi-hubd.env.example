# Optional env-var overrides, loaded by the packaged systemd unit via EnvironmentFile=- (the
# leading "-" means this file is not required to exist). Anything set here overrides the matching
# key in /etc/mimi-hubd/mimi-hubd.toml. Useful for pinning one setting (e.g. MIMI_BIND_ADDR in a
# container) without maintaining two config files, or for running purely on env vars: copy this
# file to /etc/mimi-hubd/mimi-hubd.env, set every value below, and edit the unit's ExecStart= to
# drop --config entirely (systemctl edit mimi-hubd) for the original env-only interface.
#
# MIMI_PROVIDER_DOMAIN=hub.example.org
# MIMI_BIND_ADDR=0.0.0.0:8443
# MIMI_DB_PATH=/var/lib/mimi-hubd/hub.db
# MIMI_SERVER_CERT=/etc/mimi-hubd/server-cert.pem
# MIMI_SERVER_KEY=/etc/mimi-hubd/server-key.pem
# MIMI_CLIENT_CA=/etc/mimi-hubd/ca-cert.pem
